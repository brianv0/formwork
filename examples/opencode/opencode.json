{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "mcp": {
    "files": {
      "type": "local",
      "enabled": true,
      "command": [
        "formwork",
        "gateway",
        "--blueprint", "./examples/blueprints/mcp-gateway.toml",
        "--server", "files",
        "--",
        "npx", "-y", "@modelcontextprotocol/server-filesystem", "."
      ]
    }
  }
}
